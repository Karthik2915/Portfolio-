<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Dev Portfolio</title>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #080b10; --surface: #0d1117; --card: #111820; --border: #1e2d3d;
      --accent: #00d4ff; --accent2: #7c4dff; --accent3: #ff6b35;
      --accent4: #22c55e; --accent5: #f59e0b;
      --text: #e2e8f0; --muted: #64748b;
    }
    html { scroll-behavior: smooth; }
    body { background: var(--bg); color: var(--text); font-family: 'DM Mono', monospace; overflow-x: hidden; cursor: none; }

    .cursor { width: 10px; height: 10px; background: var(--accent); border-radius: 50%; position: fixed; pointer-events: none; z-index: 9999; mix-blend-mode: screen; transition: transform 0.1s ease, background 0.2s; }
    .cursor-ring { width: 34px; height: 34px; border: 1.5px solid var(--accent); border-radius: 50%; position: fixed; pointer-events: none; z-index: 9998; opacity: 0.45; transition: all 0.15s ease; }
    body::before { content: ''; position: fixed; inset: 0; background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E"); opacity: 0.028; pointer-events: none; z-index: 9000; }

    /* NAV */
    nav { position: fixed; top: 0; left: 0; right: 0; z-index: 500; display: flex; justify-content: space-between; align-items: center; padding: 1.2rem 3rem; backdrop-filter: blur(20px); border-bottom: 1px solid var(--border); background: rgba(8,11,16,0.88); }
    .nav-logo { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 1.05rem; letter-spacing: -0.02em; }
    .nav-logo span { color: var(--accent); }
    .nav-links { display: flex; gap: 2rem; list-style: none; }
    .nav-links a { color: var(--muted); text-decoration: none; font-size: 0.72rem; letter-spacing: 0.1em; text-transform: uppercase; transition: color 0.2s; }
    .nav-links a:hover { color: var(--accent); }

    /* HERO */
    #hero { min-height: 100vh; display: flex; flex-direction: column; justify-content: center; padding: 8rem 3rem 5rem; position: relative; overflow: hidden; }
    .hero-grid { position: absolute; inset: 0; background-image: linear-gradient(rgba(0,212,255,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(0,212,255,0.04) 1px, transparent 1px); background-size: 60px 60px; mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black, transparent); }
    .orb { position: absolute; border-radius: 50%; filter: blur(110px); pointer-events: none; }
    .orb-1 { width: 550px; height: 550px; background: radial-gradient(circle, rgba(0,212,255,0.11), transparent 70%); top: -120px; right: -80px; animation: floatOrb 9s ease-in-out infinite; }
    .orb-2 { width: 420px; height: 420px; background: radial-gradient(circle, rgba(124,77,255,0.09), transparent 70%); bottom: 0; left: 5%; animation: floatOrb 12s ease-in-out infinite reverse; }
    .orb-3 { width: 300px; height: 300px; background: radial-gradient(circle, rgba(255,107,53,0.07), transparent 70%); top: 40%; right: 20%; animation: floatOrb 7s ease-in-out infinite 2s; }
    @keyframes floatOrb { 0%,100%{transform:translateY(0) scale(1)} 50%{transform:translateY(-35px) scale(1.04)} }

    .hero-eyebrow { font-size: 0.68rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--accent); margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.75rem; opacity: 0; animation: fadeUp 0.6s 0.15s forwards; }
    .hero-eyebrow::before { content: ''; width: 36px; height: 1px; background: var(--accent); }
    .hero-name { font-family: 'Syne', sans-serif; font-size: clamp(3.8rem,9vw,8.5rem); font-weight: 800; line-height: 0.92; letter-spacing: -0.04em; margin-bottom: 0.2rem; opacity: 0; animation: fadeUp 0.6s 0.3s forwards; }
    .hero-name .outline { display: block; -webkit-text-stroke: 1.5px var(--accent); color: transparent; }
    .hero-title { font-family: 'Syne', sans-serif; font-size: clamp(0.95rem,2.2vw,1.3rem); font-weight: 400; color: var(--muted); margin-top: 1.5rem; margin-bottom: 2.5rem; max-width: 560px; line-height: 1.65; opacity: 0; animation: fadeUp 0.6s 0.45s forwards; }
    .hero-title strong { color: var(--text); font-weight: 600; }
    .hero-cta { display: flex; gap: 1rem; flex-wrap: wrap; opacity: 0; animation: fadeUp 0.6s 0.6s forwards; }
    .btn { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.72rem 1.6rem; font-family: 'DM Mono', monospace; font-size: 0.72rem; letter-spacing: 0.1em; text-transform: uppercase; text-decoration: none; border-radius: 4px; transition: all 0.25s; cursor: none; }
    .btn-primary { background: var(--accent); color: #000; font-weight: 500; }
    .btn-primary:hover { background: #fff; box-shadow: 0 0 28px rgba(0,212,255,0.4); transform: translateY(-2px); }
    .btn-ghost { border: 1px solid var(--border); color: var(--muted); }
    .btn-ghost:hover { border-color: var(--accent); color: var(--accent); transform: translateY(-2px); }
    .hero-scroll { position: absolute; bottom: 2.5rem; left: 3rem; font-size: 0.62rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--muted); display: flex; align-items: center; gap: 0.75rem; opacity: 0; animation: fadeUp 0.6s 1s forwards; }
    .scroll-line { width: 1px; height: 48px; background: linear-gradient(to bottom, var(--accent), transparent); animation: scrollPulse 2s ease-in-out infinite; }
    @keyframes scrollPulse { 0%,100%{opacity:1} 50%{opacity:0.25} }
    .hero-counter { position: absolute; right: 3rem; top: 50%; transform: translateY(-50%); display: flex; flex-direction: column; gap: 1.5rem; opacity: 0; animation: fadeUp 0.6s 0.8s forwards; }
    .counter-item { text-align: right; }
    .counter-num { font-family: 'Syne', sans-serif; font-size: 2.2rem; font-weight: 800; line-height: 1; color: var(--accent); }
    .counter-lbl { font-size: 0.6rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted); }
    @keyframes fadeUp { from{opacity:0;transform:translateY(22px)} to{opacity:1;transform:translateY(0)} }

    /* SECTIONS */
    section { padding: 6rem 3rem; }
    .sec-label { font-size: 0.63rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--accent); margin-bottom: 0.9rem; display: flex; align-items: center; gap: 0.75rem; }
    .sec-label::after { content:''; flex:1; max-width:50px; height:1px; background:var(--accent); }
    .sec-title { font-family: 'Syne', sans-serif; font-size: clamp(2rem,4vw,3rem); font-weight: 800; letter-spacing: -0.03em; margin-bottom: 0.9rem; }
    .sec-sub { color: var(--muted); font-size: 0.82rem; line-height: 1.85; max-width: 520px; margin-bottom: 3.5rem; }

    /* ABOUT */
    #about { border-top: 1px solid var(--border); }
    .about-grid { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 4rem; align-items: start; }
    .about-text p { color: var(--muted); font-size: 0.82rem; line-height: 2; margin-bottom: 1.2rem; }
    .about-text p strong { color: var(--text); }
    .stats-row { display: grid; grid-template-columns: repeat(3,1fr); gap: 0.85rem; margin-top: 2rem; }
    .stat-card { background: var(--card); border: 1px solid var(--border); border-radius: 8px; padding: 1.25rem; text-align: center; }
    .stat-number { font-family: 'Syne', sans-serif; font-size: 2rem; font-weight: 800; color: var(--accent); display: block; }
    .stat-label { font-size: 0.62rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); margin-top: 0.25rem; }
    .skills-panel { background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 1.75rem; }
    .skills-panel h3 { font-family: 'Syne', sans-serif; font-size: 0.85rem; font-weight: 700; margin-bottom: 1.4rem; color: var(--muted); letter-spacing: 0.04em; }
    .skill-group { margin-bottom: 1.4rem; }
    .skill-gname { font-size: 0.62rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--accent); margin-bottom: 0.65rem; }
    .skill-tags { display: flex; flex-wrap: wrap; gap: 0.45rem; }
    .tag { background: rgba(0,212,255,0.06); border: 1px solid rgba(0,212,255,0.15); color: var(--text); padding: 0.28rem 0.7rem; border-radius: 3px; font-size: 0.68rem; letter-spacing: 0.03em; transition: all 0.2s; }
    .tag:hover { background: rgba(0,212,255,0.12); border-color: var(--accent); color: var(--accent); }
    .tag.p { background: rgba(124,77,255,0.06); border-color: rgba(124,77,255,0.2); }
    .tag.p:hover { background: rgba(124,77,255,0.14); border-color: var(--accent2); color: var(--accent2); }
    .tag.o { background: rgba(255,107,53,0.06); border-color: rgba(255,107,53,0.2); }
    .tag.o:hover { background: rgba(255,107,53,0.14); border-color: var(--accent3); color: var(--accent3); }
    .tag.g { background: rgba(34,197,94,0.06); border-color: rgba(34,197,94,0.2); }
    .tag.g:hover { background: rgba(34,197,94,0.14); border-color: var(--accent4); color: var(--accent4); }

    /* PROJECTS */
    #projects { border-top: 1px solid var(--border); }
    .projects-grid { display: grid; grid-template-columns: repeat(12,1fr); gap: 1.25rem; }
    .project-card { background: var(--card); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; transition: all 0.35s cubic-bezier(0.23,1,0.32,1); display: flex; flex-direction: column; }
    .project-card:hover { transform: translateY(-5px); box-shadow: 0 20px 55px rgba(0,0,0,0.45); }
    .pc-wide  { grid-column: span 7; }
    .pc-slim  { grid-column: span 5; }
    .pc-third { grid-column: span 4; }
    .pc-1:hover { border-color: var(--accent);  box-shadow: 0 20px 55px rgba(0,0,0,0.45), 0 0 0 1px rgba(0,212,255,0.1); }
    .pc-2:hover { border-color: var(--accent2); box-shadow: 0 20px 55px rgba(0,0,0,0.45), 0 0 0 1px rgba(124,77,255,0.1); }
    .pc-3:hover { border-color: var(--accent3); box-shadow: 0 20px 55px rgba(0,0,0,0.45), 0 0 0 1px rgba(255,107,53,0.1); }
    .pc-4:hover { border-color: var(--accent4); box-shadow: 0 20px 55px rgba(0,0,0,0.45), 0 0 0 1px rgba(34,197,94,0.1); }
    .pc-5:hover { border-color: var(--accent5); box-shadow: 0 20px 55px rgba(0,0,0,0.45), 0 0 0 1px rgba(245,158,11,0.1); }

    .project-thumb { position: relative; overflow: hidden; flex-shrink: 0; height: 200px; display: flex; align-items: center; justify-content: center; }
    .pc-wide .project-thumb { height: 230px; }
    .thumb-inner { font-size: 4rem; transition: transform 0.5s cubic-bezier(0.23,1,0.32,1); user-select: none; }
    .project-card:hover .thumb-inner { transform: scale(1.12) rotate(-3deg); }
    .t1 { background: linear-gradient(135deg, #050d1a 0%, #0a1e35 60%, #061228 100%); }
    .t2 { background: linear-gradient(135deg, #150a2a 0%, #251540 60%, #0e061e 100%); }
    .t3 { background: linear-gradient(135deg, #1a0e06 0%, #2e1a0c 60%, #150a04 100%); }
    .t4 { background: linear-gradient(135deg, #081a10 0%, #0e2e1a 60%, #051208 100%); }
    .t5 { background: linear-gradient(135deg, #1a1404 0%, #2e230a 60%, #120e02 100%); }
    .thumb-badge { position: absolute; top: 0.9rem; right: 0.9rem; background: rgba(0,0,0,0.65); backdrop-filter: blur(10px); border: 1px solid var(--border); padding: 0.22rem 0.55rem; border-radius: 3px; font-size: 0.58rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); }
    .pc-1 .thumb-badge { border-color: rgba(0,212,255,0.35); color: var(--accent); }
    .pc-2 .thumb-badge { border-color: rgba(124,77,255,0.35); color: var(--accent2); }
    .pc-3 .thumb-badge { border-color: rgba(255,107,53,0.35); color: var(--accent3); }
    .pc-4 .thumb-badge { border-color: rgba(34,197,94,0.35); color: var(--accent4); }
    .pc-5 .thumb-badge { border-color: rgba(245,158,11,0.35); color: var(--accent5); }
    .thumb-num { position: absolute; bottom: 0.9rem; left: 0.9rem; font-family: 'Syne', sans-serif; font-size: 3.5rem; font-weight: 800; opacity: 0.06; line-height: 1; color: var(--text); pointer-events: none; }

    .project-body { padding: 1.4rem; flex: 1; display: flex; flex-direction: column; }
    .project-name { font-family: 'Syne', sans-serif; font-size: 1.15rem; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 0.6rem; }
    .project-desc { color: var(--muted); font-size: 0.76rem; line-height: 1.85; margin-bottom: 1.15rem; flex: 1; }
    .ai-features { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-bottom: 1.1rem; }
    .ai-pill { display: flex; align-items: center; gap: 0.3rem; background: rgba(124,77,255,0.08); border: 1px solid rgba(124,77,255,0.2); padding: 0.22rem 0.6rem; border-radius: 20px; font-size: 0.62rem; letter-spacing: 0.04em; color: var(--accent2); }
    .ai-pill::before { content: '✦'; font-size: 0.55rem; }
    .feat-pills { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-bottom: 1.1rem; }
    .feat-pill { display: flex; align-items: center; gap: 0.3rem; background: rgba(245,158,11,0.08); border: 1px solid rgba(245,158,11,0.2); padding: 0.22rem 0.6rem; border-radius: 20px; font-size: 0.62rem; letter-spacing: 0.04em; color: var(--accent5); }
    .feat-pill::before { content: '▸'; font-size: 0.55rem; }
    .project-stack { display: flex; flex-wrap: wrap; gap: 0.35rem; margin-bottom: 1.25rem; }
    .stack-badge { background: rgba(255,255,255,0.04); border: 1px solid var(--border); padding: 0.18rem 0.5rem; border-radius: 2px; font-size: 0.62rem; letter-spacing: 0.05em; color: var(--muted); }
    .project-links { display: flex; gap: 0.75rem; padding-top: 1.1rem; border-top: 1px solid var(--border); margin-top: auto; }
    .project-link { display: flex; align-items: center; gap: 0.4rem; font-size: 0.67rem; letter-spacing: 0.08em; text-transform: uppercase; text-decoration: none; color: var(--muted); transition: color 0.2s; }
    .pc-1 .project-link:hover { color: var(--accent); }
    .pc-2 .project-link:hover { color: var(--accent2); }
    .pc-3 .project-link:hover { color: var(--accent3); }
    .pc-4 .project-link:hover { color: var(--accent4); }
    .pc-5 .project-link:hover { color: var(--accent5); }
    .project-link svg { width: 12px; height: 12px; }

    /* CONTACT */
    #contact { border-top: 1px solid var(--border); }
    .contact-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center; }
    .contact-big { font-family: 'Syne', sans-serif; font-size: clamp(2.8rem,5.5vw,5rem); font-weight: 800; letter-spacing: -0.04em; line-height: 0.95; margin-bottom: 1.5rem; }
    .contact-big .outline { -webkit-text-stroke: 1.5px var(--text); color: transparent; }
    .contact-sub { color: var(--muted); font-size: 0.8rem; line-height: 1.9; margin-bottom: 2rem; }
    .contact-email { display: inline-flex; align-items: center; gap: 0.6rem; font-size: 0.82rem; color: var(--accent); text-decoration: none; border-bottom: 1px solid rgba(0,212,255,0.3); padding-bottom: 2px; transition: border-color 0.2s; }
    .contact-email:hover { border-color: var(--accent); }
    .social-grid { display: flex; flex-direction: column; gap: 0.75rem; }
    .social-btn { display: flex; align-items: center; gap: 0.75rem; background: var(--card); border: 1px solid var(--border); padding: 0.9rem 1.25rem; border-radius: 8px; text-decoration: none; color: var(--muted); font-size: 0.72rem; letter-spacing: 0.06em; transition: all 0.22s; }
    .social-btn:hover { border-color: var(--accent); color: var(--accent); transform: translateX(6px); }
    .social-btn svg { width: 16px; height: 16px; opacity: 0.6; }
    .social-btn-name { flex: 1; }
    .social-btn-arrow { margin-left: auto; opacity: 0.4; }

    footer { border-top: 1px solid var(--border); padding: 1.75rem 3rem; display: flex; justify-content: space-between; align-items: center; }
    .footer-copy { font-size: 0.63rem; letter-spacing: 0.1em; color: var(--muted); }
    .footer-copy span { color: var(--accent); }
    .footer-status { display: flex; align-items: center; gap: 0.5rem; font-size: 0.63rem; letter-spacing: 0.1em; color: var(--muted); }
    .status-dot { width: 6px; height: 6px; background: #22c55e; border-radius: 50%; animation: statusPulse 2s ease-in-out infinite; }
    @keyframes statusPulse { 0%,100%{box-shadow:0 0 0 0 rgba(34,197,94,0.4)} 50%{box-shadow:0 0 0 6px rgba(34,197,94,0)} }

    @media (max-width: 900px) {
      nav { padding: 1rem 1.5rem; }
      section { padding: 5rem 1.5rem; }
      #hero { padding: 7rem 1.5rem 5rem; }
      .hero-counter { display: none; }
      .pc-wide, .pc-slim, .pc-third { grid-column: span 12; }
      .about-grid, .contact-inner { grid-template-columns: 1fr; gap: 2.5rem; }
      footer { flex-direction: column; gap: 0.75rem; text-align: center; }
    }
  </style>
</head>
<body>
  <div class="cursor" id="cursor"></div>
  <div class="cursor-ring" id="cursorRing"></div>

  <nav>
    <div class="nav-logo">dev<span>.</span>portfolio</div>
    <ul class="nav-links">
      <li><a href="#about">About</a></li>
      <li><a href="#projects">Projects</a></li>
      <li><a href="#contact">Contact</a></li>
    </ul>
  </nav>

  <section id="hero">
    <div class="hero-grid"></div>
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>
    <div class="hero-eyebrow">Full-Stack Developer · MERN Stack</div>
    <h1 class="hero-name">Your<br/><span class="outline">Name Here</span></h1>
    <p class="hero-title">
      I build <strong>full-stack web applications</strong> — from AI-powered reading platforms
      to social communities and anime experiences. 5 real projects, real code.
    </p>
    <div class="hero-cta">
      <a href="#projects" class="btn btn-primary">View Projects →</a>
      <a href="#contact" class="btn btn-ghost">Get In Touch</a>
    </div>
    <div class="hero-scroll"><div class="scroll-line"></div>Scroll to explore</div>
    <div class="hero-counter">
      <div class="counter-item"><div class="counter-num">5</div><div class="counter-lbl">Projects</div></div>
      <div class="counter-item"><div class="counter-num">AI</div><div class="counter-lbl">Powered</div></div>
      <div class="counter-item"><div class="counter-num">MERN</div><div class="counter-lbl">Stack</div></div>
    </div>
  </section>

  <section id="about">
    <div class="about-grid">
      <div class="about-text">
        <div class="sec-label">About me</div>
        <h2 class="sec-title">Code with<br/>purpose.</h2>
        <p>I'm a <strong>full-stack web developer</strong> who loves building complete, feature-rich applications across the entire stack — from MongoDB schemas to pixel-perfect React UIs.</p>
        <p>My projects range from <strong>AI-integrated reading platforms</strong> with text-to-speech and smart book recommendations, to <strong>e-commerce systems</strong>, social apps, and full anime entertainment platforms.</p>
        <p>I care about shipping things that <strong>actually work</strong> — clean APIs, maintainable code, and experiences users enjoy coming back to.</p>
        <div class="stats-row">
          <div class="stat-card"><span class="stat-number">5</span><div class="stat-label">Projects</div></div>
          <div class="stat-card"><span class="stat-number">AI</span><div class="stat-label">Integrated</div></div>
          <div class="stat-card"><span class="stat-number">∞</span><div class="stat-label">Curiosity</div></div>
        </div>
      </div>
      <div class="skills-panel">
        <h3>// Tech Stack</h3>
        <div class="skill-group">
          <div class="skill-gname">Frontend</div>
          <div class="skill-tags"><span class="tag">React.js</span><span class="tag">JavaScript</span><span class="tag">HTML5</span><span class="tag">CSS3</span><span class="tag">Tailwind</span></div>
        </div>
        <div class="skill-group">
          <div class="skill-gname">Backend</div>
          <div class="skill-tags"><span class="tag p">Node.js</span><span class="tag p">Express.js</span><span class="tag p">REST API</span><span class="tag p">JWT Auth</span><span class="tag p">Socket.io</span></div>
        </div>
        <div class="skill-group">
          <div class="skill-gname">AI & Data</div>
          <div class="skill-tags"><span class="tag g">AI Integration</span><span class="tag g">Text-to-Speech</span><span class="tag g">MongoDB</span><span class="tag g">Mongoose</span></div>
        </div>
        <div class="skill-group">
          <div class="skill-gname">Tools</div>
          <div class="skill-tags"><span class="tag o">Git</span><span class="tag o">GitHub</span><span class="tag o">Postman</span><span class="tag o">VS Code</span></div>
        </div>
      </div>
    </div>
  </section>

  <section id="projects">
    <div class="sec-label">My work</div>
    <h2 class="sec-title">5 Projects</h2>
    <p class="sec-sub">Full-stack applications built from scratch — each with real features, real data, and real users in mind.</p>

    <div class="projects-grid">

      <!-- 1. BookVerse FEATURED WIDE -->
      <div class="project-card pc-wide pc-1">
        <div class="project-thumb t4">
          <div class="thumb-inner">📚</div>
          <span class="thumb-badge">AI-Powered</span>
          <div class="thumb-num">01</div>
        </div>
